[Unit]
Description=WP Packages Aggregate Install Metrics

[Service]
Type=oneshot
User=deploy
Group=www-data
WorkingDirectory={{ app_root }}/current
ExecStart={{ app_root }}/current/{{ go_binary_name }} aggregate-installs --db {{ db_path }}
StandardOutput=append:{{ app_root }}/shared/storage/logs/aggregate.log
StandardError=append:{{ app_root }}/shared/storage/logs/aggregate.log
EnvironmentFile={{ app_root }}/shared/.env
